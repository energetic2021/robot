<?xml version="1.0"?>
<launch>
    <!-- 点云转激光节点 -->
    <node pkg="pointcloud_to_laserscan" type="pointcloud_to_laserscan_node" name="pointcloud_to_laserscan">
        <remap from="cloud_in" to="/depth_camera/depth/points"/>
        <remap from="scan" to="/virtual_scan"/>
        
        <rosparam>
            target_frame: laser
            transform_tolerance: 0.01
            min_height: 0.0
            max_height: 1.0
            angle_min: -3.14159
            angle_max: 3.14159
            angle_increment: 0.0087
            scan_time: 0.033
            range_min: 0.2
            range_max: 5.0
            use_inf: true
            inf_epsilon: 1.0
            concurrency_level: 1
        </rosparam>
    </node>
</launch>