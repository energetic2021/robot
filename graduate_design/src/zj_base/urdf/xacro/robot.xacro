  </gazebo>
  <gazebo reference="drawer2base_link">
    <stopCfm>0.0</stopCfm>
    <stopErp>0.2</stopErp>
    <!-- 降低ERP -->
    <provideFeedback>true</provideFeedback>
    <physics>
      <ode>
        <limit>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <!-- 降低ERP -->
        </limit>
        <fdir1>1 0 0</fdir1>
        <friction>1.0 0.5 0.0</friction>
        <!-- 大幅降低摩擦 -->
        <suspension>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <!-- 降低ERP -->
        </suspension>
      </ode>
    </physics>
  </gazebo>
