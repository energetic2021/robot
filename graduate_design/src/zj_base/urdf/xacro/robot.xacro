        <mesh filename="package://zj_base/meshes/box.stl"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <surface>
        <friction>
          <ode>
            <mu>0.3</mu>
            <!-- 大幅降低摩擦 -->
            <mu2>0.1</mu2>
            <!-- 大幅降低摩擦 -->
          </ode>
        </friction>
      </surface>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <!-- 减轻质量 -->
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      <!-- 减小惯性 -->
    </inertial>
  </link>
  <joint name="drawer2base_link" type="prismatic">
    <parent link="base_link"/>
    <child link="drawer"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <!-- 保持位置不变 -->
    <axis xyz="1 0 0"/>
    <limit effort="500" lower="0" upper="0.2" velocity="2.0"/>
    <!-- 只增加effort -->
    <dynamics damping="0.01" friction="0.0"/>
    <!-- 大幅减少阻尼和摩擦 -->
  </joint>
  <gazebo reference="drawer">
    <material>Gazebo/Grey</material>
    <mu1>0.3</mu1>
    <!-- 降低Gazebo摩擦 -->
    <mu2>0.1</mu2>
