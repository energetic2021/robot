  <joint name="drawer32base_link" type="prismatic">
    <parent link="base_link"/>
    <child link="drawer3"/>
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit effort="1000" lower="0" upper="0.2" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.0"/>
  </joint>

  <gazebo reference="drawer3">
    <material>Gazebo/Grey</material>
    <selfCollide>true</selfCollide>
    <mu1>1.0</mu1>
    <mu2>0.8</mu2>
    <kp>1e12</kp>
    <kd>1000.0</kd>
    <minDepth>0.0001</minDepth>
    <maxVel>10.0</maxVel>
    <laserRetro>0</laserRetro>
  </gazebo>

  <gazebo reference="drawer32base_link">
    <stopCfm>0.0</stopCfm>
    <stopErp>0.9</stopErp>
    <provideFeedback>true</provideFeedback>
    <physics>
      <ode>
        <limit>
          <cfm>0.0</cfm>
          <erp>0.9</erp>
        </limit>
        <fdir1>1 0 0</fdir1>
        <friction>1.0 0.8 0.0</friction>
        <suspension>
          <cfm>0.0</cfm>
          <erp>0.9</erp>
        </suspension>
      </ode>
    </physics>
  </gazebo>

</robot>